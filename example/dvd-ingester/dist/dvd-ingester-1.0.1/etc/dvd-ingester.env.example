# dvd-ingester configuration

# Cold destination for completed DVD output. In apply mode this should be a
# mounted NAS/media filesystem. The runtime refuses unmounted destinations when
# findmnt is available unless ALLOW_UNMOUNTED_DEST=1 is set.
DEST_DIR=/mnt/media/dvd-ingester

# Local hot handoff storage. Rip jobs move completed output here before the
# publish drain copies it to DEST_DIR with an atomic final rename.
HOT_DIR=/var/cache/dvd-ingester/hot

# Temporary work area used during a rip before hot handoff.
WORK_DIR=/var/lib/dvd-ingester/work

# Runtime state directory for JSON status and lock files.
STATE_DIR=/run/dvd-ingester

# Minimum free space required in HOT_DIR before a rip begins.
MIN_HOT_FREE_BYTES=10737418240
CAPACITY_TIMEOUT_SECONDS=900
CAPACITY_INTERVAL_SECONDS=5

# Optional command override. It receives DEVICE, RUN_DIR, RUN_ID, and
# DEVICE_FINGERPRINT in the environment. Leave empty to use dvdbackup or
# makemkvcon when available.
RIP_COMMAND=

# Eject disc after a successful hot handoff.
EJECT_AFTER_RIP=1

# Set to 1 only when DEST_DIR is intentionally local storage.
ALLOW_UNMOUNTED_DEST=0

# Set to 0 to disable update polling.
AUTOUPDATE=1

# Release manifest used by bin/update.sh.
UPDATE_MANIFEST_URL=https://github.com/azide0x37/dvd-ingester/releases/latest/download/manifest.json

# Home Assistant MQTT bridge defaults live in dvd-ingester.mqtt.env so broker
# secrets can be protected separately from this general appliance config.
