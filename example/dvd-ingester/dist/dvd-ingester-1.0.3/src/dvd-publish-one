#!/bin/sh
set -eu

PROJECT="dvd-ingester"
APPLY=0
ONCE=0

usage() {
  printf '%s\n' "Usage: dvd-publish-one [--apply] [--once]"
}

while [ $# -gt 0 ]; do
  case "$1" in
    --apply) APPLY=1 ;;
    --once) ONCE=1 ;;
    -h|--help) usage; exit 0 ;;
    *) printf '%s\n' "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if [ "$APPLY" = "1" ]; then
  CONFIG_FILE="${CONFIG_FILE:-/etc/$PROJECT/$PROJECT.env}"
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
  fi
  STATE_DIR="${STATE_DIR:-/run/$PROJECT}"
  HOT_DIR="${HOT_DIR:-/var/cache/$PROJECT/hot}"
  DEST_DIR="${DEST_DIR:-/mnt/media/$PROJECT}"
else
  if [ -n "${CONFIG_FILE:-}" ] && [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
  fi
  MOCK_ROOT="${MUSTER_MOCK_ROOT:-${TMPDIR:-/tmp}/$PROJECT-mock}"
  STATE_DIR="${STATE_DIR:-$MOCK_ROOT/run/$PROJECT}"
  HOT_DIR="${HOT_DIR:-$MOCK_ROOT/var/cache/$PROJECT/hot}"
  DEST_DIR="${DEST_DIR:-$MOCK_ROOT/mnt/$PROJECT}"
fi

ALLOW_UNMOUNTED_DEST="${ALLOW_UNMOUNTED_DEST:-0}"
LOCK_FILE="$STATE_DIR/publish.lock"

mkdir -p "$STATE_DIR" "$HOT_DIR"
if [ "$APPLY" != "1" ]; then
  mkdir -p "$DEST_DIR"
fi

write_publish_state() {
  state="$1"
  reason="$2"
  published="$3"
  failed="$4"
  printf '{"state":"%s","reason":"%s","published":%s,"failed":%s,"hot_dir":"%s","dest_dir":"%s","once":%s}\n' \
    "$state" "$reason" "$published" "$failed" "$HOT_DIR" "$DEST_DIR" "$ONCE" > "$STATE_DIR/publish.json"
}

require_capability() {
  if [ "$APPLY" = "1" ] && [ "$ALLOW_UNMOUNTED_DEST" != "1" ] && command -v findmnt >/dev/null 2>&1; then
    if ! findmnt "$DEST_DIR" >/dev/null 2>&1; then
      write_publish_state degraded capability_not_mounted 0 1
      printf '%s\n' "degraded: destination is not mounted: $DEST_DIR" >&2
      exit 75
    fi
  fi

  if [ "$ALLOW_UNMOUNTED_DEST" = "1" ]; then
    mkdir -p "$DEST_DIR"
  fi

  if [ ! -d "$DEST_DIR" ] || [ ! -w "$DEST_DIR" ]; then
    write_publish_state failed capability_unavailable 0 1
    printf '%s\n' "failed: destination is not writable: $DEST_DIR" >&2
    exit 1
  fi
}

copy_to_temp() {
  item="$1"
  tmp="$2"
  mkdir -p "$tmp"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete "$item"/ "$tmp"/
  else
    cp -Rp "$item/." "$tmp/"
  fi
}

publish_once() {
  published=0
  failed=0

  for item in "$HOT_DIR"/*; do
    [ -e "$item" ] || continue
    [ -d "$item" ] || continue
    [ -f "$item/.ingest-complete" ] || continue

    name=$(basename "$item")
    target="$DEST_DIR/$name"
    tmp="$DEST_DIR/.incoming-$name-$$"

    if [ -e "$target" ]; then
      failed=$((failed + 1))
      write_publish_state degraded target_exists "$published" "$failed"
      continue
    fi

    rm -rf "$tmp"
    if ! copy_to_temp "$item" "$tmp"; then
      failed=$((failed + 1))
      rm -rf "$tmp"
      write_publish_state failed copy_failed "$published" "$failed"
      continue
    fi

    touch "$tmp/.publish-complete"
    mv "$tmp" "$target"
    rm -rf "$item"
    published=$((published + 1))
  done

  if [ "$failed" -gt 0 ]; then
    write_publish_state degraded drain_completed_with_failures "$published" "$failed"
  else
    write_publish_state healthy drain_complete "$published" "$failed"
  fi
}

if command -v flock >/dev/null 2>&1 && [ "${MUSTER_FORCE_LOCKDIR:-0}" != "1" ]; then
  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    write_publish_state degraded already_running 0 1
    printf '%s\n' "degraded: another publish job is running" >&2
    exit 75
  fi
else
  lock_dir="$STATE_DIR/publish.lockdir"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    write_publish_state degraded already_running 0 1
    printf '%s\n' "degraded: another publish job is running" >&2
    exit 75
  fi
  trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT INT TERM
fi

require_capability
publish_once

printf '%s\n' "ok: $PROJECT publish drain complete"
