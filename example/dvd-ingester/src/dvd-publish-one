#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${DVD_INGESTER_CONFIG:-/etc/dvd-ingester/dvd-ingester.env}"
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

METADATA_FILE="${1:?metadata file required}"
BASE_DIR="${BASE_DIR:-/var/lib/dvd-ingester}"
LOG_DIR="${LOG_DIR:-$BASE_DIR/logs}"
RIPPED_DB="${RIPPED_DB:-$BASE_DIR/ripped.jsonl}"
RSYNC_RETRIES="${RSYNC_RETRIES:-3}"
RSYNC_RETRY_SLEEP="${RSYNC_RETRY_SLEEP:-30}"
PUBLISH_LOCK="${PUBLISH_LOCK:-/run/dvd-ingester-publish.lock}"

metadata_value() {
  jq -r --arg key "$1" '.[$key] // empty' "$METADATA_FILE"
}

FP="$(metadata_value fingerprint)"
LABEL="$(metadata_value label)"
RIP_MODE="$(metadata_value mode)"
FINAL="$(metadata_value final)"
PART="$(metadata_value part)"
RUN_DIR="$(metadata_value run_dir)"

if [ -z "$FP" ] || [ -z "$LABEL" ] || [ -z "$RIP_MODE" ] || [ -z "$FINAL" ] || [ -z "$PART" ] || [ -z "$RUN_DIR" ]; then
  echo "metadata is missing required fields: $METADATA_FILE" >&2
  exit 2
fi

LOG_FILE="$LOG_DIR/$FP.log"

log() {
  if command -v systemd-cat >/dev/null 2>&1; then
    echo "$*" | systemd-cat -t dvd-ingester
  else
    echo "$*"
  fi
}

append_log() {
  printf '%s %s\n' "$(date -Is)" "$*" >> "$LOG_FILE"
}

log_tail() {
  if [ -s "$LOG_FILE" ]; then
    log "Last log lines from $LOG_FILE:"
    tail -n 40 "$LOG_FILE" | while IFS= read -r line; do
      log "  $line"
    done
  fi
}

rsync_publish() {
  source_path="$1"
  destination_path="$2"
  attempt=1
  rc=1

  while [ "$attempt" -le "$RSYNC_RETRIES" ]; do
    append_log "rsync publish attempt $attempt/$RSYNC_RETRIES: $source_path -> $destination_path"
    if rsync -a --delete --partial --partial-dir=.rsync-partial --append-verify "$source_path" "$destination_path" >> "$LOG_FILE" 2>&1; then
      return 0
    fi

    rc=$?
    log "rsync publish failed with exit $rc on attempt $attempt/$RSYNC_RETRIES"
    log_tail
    if [ "$attempt" -lt "$RSYNC_RETRIES" ]; then
      append_log "sleeping ${RSYNC_RETRY_SLEEP}s before rsync retry"
      sleep "$RSYNC_RETRY_SLEEP"
    fi
    attempt=$((attempt + 1))
  done

  return "$rc"
}

record_success() {
  if grep -q "\"fingerprint\":\"$FP\"" "$RIPPED_DB" 2>/dev/null; then
    return 0
  fi

  jq -cn \
    --arg fingerprint "$FP" \
    --arg disc_label "$LABEL" \
    --arg mode "$RIP_MODE" \
    --arg file "$FINAL" \
    --arg completed_at "$(date -Is)" \
    '{"fingerprint":$fingerprint,"label":$disc_label,"mode":$mode,"file":$file,"completed_at":$completed_at}' \
    >> "$RIPPED_DB"
}

mkdir -p "$LOG_DIR" "$(dirname "$FINAL")"
touch "$RIPPED_DB"

exec 8>"$PUBLISH_LOCK"
flock 8

if grep -q "\"fingerprint\":\"$FP\"" "$RIPPED_DB" 2>/dev/null; then
  log "Already published: $LABEL $FP"
  rm -rf "$RUN_DIR"
  exit 0
fi

case "$RIP_MODE" in
  movie)
    if [ -f "$FINAL" ]; then
      log "Final file already exists: $FINAL"
      record_success
      rm -rf "$RUN_DIR"
      exit 0
    fi

    append_log "publishing movie to $PART"
    rsync_publish "$RUN_DIR/output.mkv" "$PART"
    mv "$PART" "$FINAL"
    ;;
  archive)
    if [ -e "$FINAL" ]; then
      log "Final archive already exists: $FINAL"
      record_success
      rm -rf "$RUN_DIR"
      exit 0
    fi

    append_log "publishing archive to $PART"
    rsync_publish "$RUN_DIR"/ "$PART"/
    mv "$PART" "$FINAL"
    ;;
  *)
    echo "Unsupported RIP_MODE=$RIP_MODE" >&2
    exit 2
    ;;
esac

record_success
rm -rf "$RUN_DIR"
log "Done: $FINAL"
