#!/bin/sh
set -eu

PROJECT="dvd-ingester"
APPLY=0
DEVICE="/dev/sr0"

usage() {
  printf '%s\n' "Usage: dvd-rip-one [DEVICE] [--apply]"
}

if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
  DEVICE="$1"
  shift
fi

while [ $# -gt 0 ]; do
  case "$1" in
    --apply) APPLY=1 ;;
    -h|--help) usage; exit 0 ;;
    *) printf '%s\n' "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if [ "$APPLY" = "1" ]; then
  CONFIG_FILE="${CONFIG_FILE:-/etc/$PROJECT/$PROJECT.env}"
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
  fi
  STATE_DIR="${STATE_DIR:-/run/$PROJECT}"
  WORK_DIR="${WORK_DIR:-/var/lib/$PROJECT/work}"
  HOT_DIR="${HOT_DIR:-/var/cache/$PROJECT/hot}"
  DEST_DIR="${DEST_DIR:-/mnt/media/$PROJECT}"
else
  if [ -n "${CONFIG_FILE:-}" ] && [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
  fi
  MOCK_ROOT="${MUSTER_MOCK_ROOT:-${TMPDIR:-/tmp}/$PROJECT-mock}"
  STATE_DIR="${STATE_DIR:-$MOCK_ROOT/run/$PROJECT}"
  WORK_DIR="${WORK_DIR:-$MOCK_ROOT/var/lib/$PROJECT/work}"
  HOT_DIR="${HOT_DIR:-$MOCK_ROOT/var/cache/$PROJECT/hot}"
  DEST_DIR="${DEST_DIR:-$MOCK_ROOT/mnt/$PROJECT}"
fi

MIN_HOT_FREE_BYTES="${MIN_HOT_FREE_BYTES:-10737418240}"
CAPACITY_TIMEOUT_SECONDS="${CAPACITY_TIMEOUT_SECONDS:-900}"
CAPACITY_INTERVAL_SECONDS="${CAPACITY_INTERVAL_SECONDS:-5}"
RIP_COMMAND="${RIP_COMMAND:-}"
EJECT_AFTER_RIP="${EJECT_AFTER_RIP:-1}"
ALLOW_UNMOUNTED_DEST="${ALLOW_UNMOUNTED_DEST:-0}"
EJECT_ATTEMPTED=0

if [ -z "${DRAIN_COMMAND:-}" ] && [ "$APPLY" = "1" ]; then
  DRAIN_COMMAND="/opt/$PROJECT/current/bin/dvd-publish-one --apply --once"
else
  DRAIN_COMMAND="${DRAIN_COMMAND:-}"
fi

device_name=$(basename "$DEVICE" | tr -cd 'A-Za-z0-9._-' | cut -c1-64)
device_name=${device_name:-device}
LOCK_FILE="$STATE_DIR/rip.lock"
LOCK_DIR_TO_REMOVE=""
HANDOFF_TMP_TO_REMOVE=""
RUN_ID="$device_name-pending-$$"
RUN_DIR="$WORK_DIR/$RUN_ID.work"

mkdir -p "$STATE_DIR" "$WORK_DIR" "$HOT_DIR"
if [ "$APPLY" != "1" ]; then
  mkdir -p "$DEST_DIR"
fi

write_state() {
  file="$1"
  state="$2"
  reason="$3"
  printf '{"state":"%s","reason":"%s","device":"%s","run_id":"%s","work_dir":"%s","hot_dir":"%s","dest_dir":"%s"}\n' \
    "$state" "$reason" "$DEVICE" "$RUN_ID" "$WORK_DIR" "$HOT_DIR" "$DEST_DIR" > "$STATE_DIR/$file"
}

write_handoff_state() {
  state="$1"
  reason="$2"
  printf '{"state":"%s","reason":"%s","device":"%s","run_id":"%s","hot_dir":"%s","dest_dir":"%s"}\n' \
    "$state" "$reason" "$DEVICE" "$RUN_ID" "$HOT_DIR" "$DEST_DIR" > "$STATE_DIR/handoff.json"
}

cleanup_lock_dir() {
  if [ -n "$LOCK_DIR_TO_REMOVE" ]; then
    rmdir "$LOCK_DIR_TO_REMOVE" 2>/dev/null || true
  fi
}

cleanup_handoff_tmp() {
  if [ -n "$HANDOFF_TMP_TO_REMOVE" ]; then
    rm -rf "$HANDOFF_TMP_TO_REMOVE" 2>/dev/null || true
  fi
}

cleanup_exit() {
  cleanup_handoff_tmp
  cleanup_lock_dir
}

handle_interrupted() {
  set +e
  mkdir -p "$STATE_DIR"
  if [ -d "$RUN_DIR" ]; then
    rm -f "$RUN_DIR/.ingest-in-progress"
    touch "$RUN_DIR/.ingest-interrupted"
  fi
  write_state rip.json degraded interrupted
  cleanup_exit
  printf '%s\n' "degraded: rip interrupted for $DEVICE" >&2
  exit 143
}

trap handle_interrupted INT TERM HUP
trap cleanup_exit EXIT

safe_name() {
  printf '%s' "$1" | tr -cd 'A-Za-z0-9._ -' | tr ' ' '_' | cut -c1-80
}

hash_identity() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}' | cut -c1-20
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}' | cut -c1-20
  else
    cksum | awk '{print $1}' | cut -c1-20
  fi
}

probe_disc_identity() {
  DISC_LABEL="${DVD_DISC_LABEL:-}"
  DISC_UUID="${DVD_DISC_UUID:-}"
  DISC_TYPE="${DVD_DISC_TYPE:-}"
  DISC_SIZE="${DVD_DISC_SIZE:-unknown}"

  if command -v blkid >/dev/null 2>&1; then
    DISC_UUID="${DISC_UUID:-$(blkid -o value -s UUID "$DEVICE" 2>/dev/null || true)}"
    DISC_LABEL="${DISC_LABEL:-$(blkid -o value -s LABEL "$DEVICE" 2>/dev/null || true)}"
    DISC_TYPE="${DISC_TYPE:-$(blkid -o value -s TYPE "$DEVICE" 2>/dev/null || true)}"
  fi
  if [ "$DISC_SIZE" = "unknown" ] && command -v blockdev >/dev/null 2>&1; then
    DISC_SIZE="$(blockdev --getsize64 "$DEVICE" 2>/dev/null || printf '%s\n' unknown)"
  fi

  DISC_LABEL="${DISC_LABEL:-DVDVolume}"
  DISC_TYPE="${DISC_TYPE:-unknown}"
  SAFE_LABEL="$(safe_name "$DISC_LABEL")"
  SAFE_LABEL="${SAFE_LABEL:-DVDVolume}"
  DEVICE_FINGERPRINT="${DVD_DISC_FINGERPRINT:-$(printf '%s|%s|%s|%s\n' "$DISC_LABEL" "$DISC_UUID" "$DISC_TYPE" "$DISC_SIZE" | hash_identity)}"
  RUN_ID="${SAFE_LABEL}_${DEVICE_FINGERPRINT}"
  RUN_DIR="$WORK_DIR/$RUN_ID.work.$$"
}

require_capability() {
  if [ "$APPLY" = "1" ] && [ "$ALLOW_UNMOUNTED_DEST" != "1" ] && command -v findmnt >/dev/null 2>&1; then
    if ! findmnt "$DEST_DIR" >/dev/null 2>&1; then
      write_state capability.json degraded capability_not_mounted
      printf '%s\n' "degraded: destination is not mounted: $DEST_DIR" >&2
      exit 75
    fi
  fi

  if [ "$ALLOW_UNMOUNTED_DEST" = "1" ]; then
    mkdir -p "$DEST_DIR"
  fi

  if [ ! -d "$DEST_DIR" ] || [ ! -w "$DEST_DIR" ]; then
    write_state capability.json failed capability_unavailable
    printf '%s\n' "failed: destination is not writable: $DEST_DIR" >&2
    exit 1
  fi

  write_state capability.json healthy capability_available
}

available_hot_bytes() {
  if [ "${MUSTER_MOCK_BACKPRESSURE:-0}" = "1" ] && [ ! -f "$STATE_DIR/capacity-ready" ]; then
    printf '%s\n' 0
    return 0
  fi
  df -Pk "$HOT_DIR" | awk 'NR == 2 {printf "%.0f\n", $4 * 1024}'
}

write_capacity_state() {
  state="$1"
  reason="$2"
  available="$3"
  printf '{"state":"%s","reason":"%s","available_bytes":%s,"required_bytes":%s,"hot_dir":"%s"}\n' \
    "$state" "$reason" "$available" "$MIN_HOT_FREE_BYTES" "$HOT_DIR" > "$STATE_DIR/hot-capacity.json"
}

wait_for_hot_capacity() {
  start=$(date +%s)
  while :; do
    available=$(available_hot_bytes)
    if [ "$available" -ge "$MIN_HOT_FREE_BYTES" ]; then
      write_capacity_state healthy capacity_available "$available"
      return 0
    fi

    write_capacity_state degraded waiting_for_capacity "$available"
    now=$(date +%s)
    if [ "$((now - start))" -ge "$CAPACITY_TIMEOUT_SECONDS" ]; then
      write_capacity_state failed capacity_timeout "$available"
      printf '%s\n' "failed: hot capacity timeout" >&2
      exit 75
    fi

    if [ -n "$DRAIN_COMMAND" ]; then
      sh -c "$DRAIN_COMMAND" || true
    fi
    sleep "$CAPACITY_INTERVAL_SECONDS"
  done
}

run_ingest() {
  export DEVICE RUN_DIR RUN_ID DEVICE_FINGERPRINT DISC_LABEL DISC_UUID DISC_TYPE DISC_SIZE STATE_DIR WORK_DIR HOT_DIR DEST_DIR
  mkdir -p "$RUN_DIR"
  touch "$RUN_DIR/.ingest-in-progress"
  write_state rip.json active ingest_in_progress
  printf '{"device":"%s","label":"%s","uuid":"%s","type":"%s","size":"%s","fingerprint":"%s","run_id":"%s"}\n' \
    "$DEVICE" "$DISC_LABEL" "$DISC_UUID" "$DISC_TYPE" "$DISC_SIZE" "$DEVICE_FINGERPRINT" "$RUN_ID" > "$RUN_DIR/metadata.json"

  if [ -n "$RIP_COMMAND" ]; then
    sh -c "$RIP_COMMAND" || return 1
  elif [ "$APPLY" = "1" ]; then
    if command -v dvdbackup >/dev/null 2>&1; then
      dvdbackup -M -i "$DEVICE" -o "$RUN_DIR" || return 1
    elif command -v makemkvcon >/dev/null 2>&1; then
      makemkvcon mkv disc:0 all "$RUN_DIR" || return 1
    else
      printf '%s\n' "failed: neither dvdbackup nor makemkvcon is available; set RIP_COMMAND" >&2
      return 1
    fi
  else
    printf 'mock ingest from %s\n' "$DEVICE" > "$RUN_DIR/payload.txt"
  fi

  rm -f "$RUN_DIR/.ingest-in-progress"
  touch "$RUN_DIR/.ingest-complete"
  write_state rip.json active ingest_complete
}

existing_output_path() {
  if [ -e "$HOT_DIR/$RUN_ID" ]; then
    printf '%s\n' "$HOT_DIR/$RUN_ID"
    return 0
  fi
  if [ -e "$DEST_DIR/$RUN_ID" ]; then
    printf '%s\n' "$DEST_DIR/$RUN_ID"
    return 0
  fi
  return 1
}

handoff_to_hot() {
  target="$HOT_DIR/$RUN_ID"
  tmp="$HOT_DIR/.incoming-$RUN_ID-$$"
  if existing="$(existing_output_path)"; then
    write_state rip.json degraded target_exists
    eject_device
    printf '%s\n' "degraded: output already exists for $RUN_ID at $existing" >&2
    exit 75
  fi
  rm -rf "$tmp"
  HANDOFF_TMP_TO_REMOVE="$tmp"
  mkdir -p "$tmp"
  rm -f "$RUN_DIR/.ingest-complete"
  if command -v rsync >/dev/null 2>&1; then
    rsync -a --delete "$RUN_DIR"/ "$tmp"/
  else
    cp -Rp "$RUN_DIR/." "$tmp/"
  fi
  touch "$tmp/.ingest-complete"
  mv "$tmp" "$target"
  HANDOFF_TMP_TO_REMOVE=""
  rm -rf "$RUN_DIR"
  printf '{"state":"ready_for_cold_publish","device":"%s","run_id":"%s","handoff":"%s"}\n' \
    "$DEVICE" "$RUN_ID" "$target" > "$STATE_DIR/handoff.json"
}

eject_device() {
  if [ "$EJECT_ATTEMPTED" = "1" ]; then
    return 0
  fi
  EJECT_ATTEMPTED=1
  if [ "$APPLY" != "1" ] || [ "$EJECT_AFTER_RIP" != "1" ]; then
    return 0
  fi
  if ! command -v eject >/dev/null 2>&1; then
    write_state eject.json degraded eject_command_missing
    printf '%s\n' "warn: eject command not found; leaving $DEVICE loaded" >&2
    return 0
  fi
  if eject "$DEVICE"; then
    write_state eject.json healthy ejected
  else
    write_state eject.json degraded eject_failed
    printf '%s\n' "warn: eject failed for $DEVICE" >&2
  fi
}

probe_disc_identity

if command -v flock >/dev/null 2>&1 && [ "${MUSTER_FORCE_LOCKDIR:-0}" != "1" ]; then
  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    write_state rip.json degraded already_running
    printf '%s\n' "degraded: another rip job is running" >&2
    exit 75
  fi
else
  lock_dir="$STATE_DIR/rip.lockdir"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    write_state rip.json degraded already_running
    printf '%s\n' "degraded: another rip job is running" >&2
    exit 75
  fi
  LOCK_DIR_TO_REMOVE="$lock_dir"
fi

write_state event.json degraded device_event_recorded
require_capability

if existing="$(existing_output_path)"; then
  printf '{"state":"healthy","reason":"target_exists","device":"%s","run_id":"%s","output":"%s"}\n' \
    "$DEVICE" "$RUN_ID" "$existing" > "$STATE_DIR/rip.json"
  eject_device
  printf '%s\n' "ok: $PROJECT output already exists for $RUN_ID"
  exit 0
fi

write_handoff_state waiting_for_extraction ingest_in_progress
wait_for_hot_capacity

if ! run_ingest; then
  rm -f "$RUN_DIR/.ingest-in-progress"
  mkdir -p "$RUN_DIR"
  touch "$RUN_DIR/.ingest-failed"
  write_state rip.json failed ingest_failed
  exit 1
fi

eject_device
write_state rip.json active handoff_to_hot
handoff_to_hot
write_state rip.json healthy ready_for_cold_publish

printf '%s\n' "ok: $PROJECT staged $RUN_ID"
