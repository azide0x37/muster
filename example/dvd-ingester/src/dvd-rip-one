#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${DVD_INGESTER_CONFIG:-/etc/dvd-ingester/dvd-ingester.env}"
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

DEV="${1:-/dev/sr0}"
BASE_DIR="${BASE_DIR:-/var/lib/dvd-ingester}"
WORK_DIR="${WORK_DIR:-$BASE_DIR/work}"
LOG_DIR="${LOG_DIR:-$BASE_DIR/logs}"
RIPPED_DB="${RIPPED_DB:-$BASE_DIR/ripped.jsonl}"
DEST_DIR="${DEST_DIR:-/mnt/nas/DVD_Rips}"
RIP_MODE="${RIP_MODE:-movie}"
HANDBRAKE_PRESET="${HANDBRAKE_PRESET:-Fast 480p30}"
MIN_TV_TITLE_SECONDS="${MIN_TV_TITLE_SECONDS:-1080}"
MEDIA_SETTLE_SECONDS="${MEDIA_SETTLE_SECONDS:-8}"
MEDIA_READY_TIMEOUT="${MEDIA_READY_TIMEOUT:-60}"
MEDIA_READY_INTERVAL="${MEDIA_READY_INTERVAL:-2}"
EJECT_ON_SUCCESS="${EJECT_ON_SUCCESS:-1}"
EJECT_ON_FAILURE="${EJECT_ON_FAILURE:-0}"
RSYNC_RETRIES="${RSYNC_RETRIES:-3}"
RSYNC_RETRY_SLEEP="${RSYNC_RETRY_SLEEP:-30}"
REQUIRE_DEST_MOUNT="${REQUIRE_DEST_MOUNT:-1}"
MIN_WORK_FREE_BYTES="${MIN_WORK_FREE_BYTES:-10737418240}"
PUBLISH_ASYNC="${PUBLISH_ASYNC:-1}"
PUBLISH_DURING_RIP="${PUBLISH_DURING_RIP:-1}"
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PUBLISH_COMMAND="${PUBLISH_COMMAND:-$SCRIPT_DIR/dvd-publish-one}"
LOCK="/run/dvd-ingester.lock"
LOG_FILE=""
EJECTED=0
RUN_DIR=""
PUBLISH_STARTED=0

log() {
  if command -v systemd-cat >/dev/null 2>&1; then
    echo "$*" | systemd-cat -t dvd-ingester
  else
    echo "$*"
  fi
}

append_log() {
  printf '%s %s\n' "$(date -Is)" "$*" >> "$LOG_FILE"
}

log_tail() {
  if [ -s "$LOG_FILE" ]; then
    log "Last log lines from $LOG_FILE:"
    tail -n 40 "$LOG_FILE" | while IFS= read -r line; do
      log "  $line"
    done
  fi
}

eject_disc() {
  if [ "$EJECTED" = "0" ]; then
    eject "$DEV" >/dev/null 2>&1 || true
    EJECTED=1
  fi
}

run_logged() {
  append_log "running: $*"
  if "$@" >> "$LOG_FILE" 2>&1; then
    return 0
  fi

  rc=$?
  log "Command failed with exit $rc: $*"
  log_tail
  return "$rc"
}

ensure_destination_ready() {
  if [ "$REQUIRE_DEST_MOUNT" = "1" ]; then
    if [ -d "$DEST_DIR" ]; then
      ls -la "$DEST_DIR" >/dev/null 2>&1 || true
    fi

    if ! findmnt "$DEST_DIR" >/dev/null 2>&1; then
      log "Destination is not mounted at $DEST_DIR; refusing to write to local storage"
      append_log "destination is not mounted at $DEST_DIR"
      return 1
    fi
    return 0
  fi

  mkdir -p "$DEST_DIR"
}

ensure_work_space_available() {
  available_bytes="$(df -Pk "$WORK_DIR" | awk 'NR == 2 {printf "%.0f\n", $4 * 1024}')"
  append_log "work filesystem available bytes: $available_bytes"

  if [ "$available_bytes" -lt "$MIN_WORK_FREE_BYTES" ]; then
    log "Not enough free space on work filesystem: available=${available_bytes} required=${MIN_WORK_FREE_BYTES}"
    append_log "not enough work filesystem space: available=${available_bytes} required=${MIN_WORK_FREE_BYTES}"
    return 1
  fi
}

write_metadata() {
  METADATA_FILE="$RUN_DIR/metadata.json"
  jq -cn \
    --arg fingerprint "$FP" \
    --arg disc_label "$LABEL" \
    --arg mode "$RIP_MODE" \
    --arg final "$FINAL" \
    --arg part "$PART" \
    --arg run_dir "$RUN_DIR" \
    '{"fingerprint":$fingerprint,"label":$disc_label,"mode":$mode,"final":$final,"part":$part,"run_dir":$run_dir}' \
    > "$METADATA_FILE"
}

start_publish_async() {
  if [ ! -x "$PUBLISH_COMMAND" ]; then
    log "Publish command is not executable: $PUBLISH_COMMAND"
    return 1
  fi

  if [ "$PUBLISH_ASYNC" = "1" ] && command -v systemd-run >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
    unit="dvd-publish-$FP"
    append_log "starting asynchronous publish unit $unit"
    if systemd-run \
      --unit "$unit" \
      --description "Publish DVD rip $LABEL" \
      --property=Nice=10 \
      --property=IOSchedulingClass=best-effort \
      --property=IOSchedulingPriority=7 \
      --collect \
      --no-block \
      "$PUBLISH_COMMAND" "$METADATA_FILE" >> "$LOG_FILE" 2>&1; then
      PUBLISH_STARTED=1
      log "Publish continues in $unit"
      return 0
    fi
    append_log "systemd-run publish failed"
  fi

  return 1
}

start_publish() {
  if start_publish_async; then
    return 0
  fi

  append_log "falling back to foreground publish"
  "$PUBLISH_COMMAND" "$METADATA_FILE"
  PUBLISH_STARTED=1
}

safe_name() {
  tr -cd 'A-Za-z0-9._ -' | tr ' ' '_' | cut -c1-80
}

finish() {
  status=$?
  if [ "$status" -ne 0 ] && [ -n "$RUN_DIR" ] && [ -d "$RUN_DIR" ]; then
    rm -f "$RUN_DIR/.rip-in-progress"
    touch "$RUN_DIR/.rip-failed"
  fi

  if { [ "$status" -eq 0 ] && [ "$EJECT_ON_SUCCESS" = "1" ]; } || { [ "$status" -ne 0 ] && [ "$EJECT_ON_FAILURE" = "1" ]; }; then
    eject_disc
  elif [ "$status" -ne 0 ]; then
    log "Leaving $DEV inserted after failure; set EJECT_ON_FAILURE=1 to eject failed discs"
  fi
}

wait_for_media() {
  log "Waiting for readable DVD media on $DEV"
  append_log "waiting for readable DVD media on $DEV"
  sleep "$MEDIA_SETTLE_SECONDS"

  start=$SECONDS
  while [ "$((SECONDS - start))" -le "$MEDIA_READY_TIMEOUT" ]; do
    if [ ! -b "$DEV" ]; then
      append_log "$DEV is not a block device yet"
    elif size="$(blockdev --getsize64 "$DEV" 2>>"$LOG_FILE")" && [ "${size:-0}" -gt 0 ] && dd if="$DEV" of=/dev/null bs=2048 count=1 iflag=fullblock status=none 2>>"$LOG_FILE"; then
      append_log "$DEV is readable; size=$size"
      return 0
    else
      append_log "$DEV is not readable yet"
    fi
    sleep "$MEDIA_READY_INTERVAL"
  done

  append_log "timed out waiting for readable media"
  if command -v udevadm >/dev/null 2>&1; then
    append_log "udev properties for $DEV:"
    udevadm info --query=property --name="$DEV" >> "$LOG_FILE" 2>&1 || true
  fi
  log "Timed out waiting for readable DVD media on $DEV after ${MEDIA_READY_TIMEOUT}s"
  log_tail
  return 1
}

exec 9>"$LOCK"
flock -n 9 || exit 0
trap finish EXIT

mkdir -p "$WORK_DIR" "$LOG_DIR"
touch "$RIPPED_DB"

PROBE_LOG_FILE="$LOG_DIR/probe-${DEV##*/}.log"
LOG_FILE="$PROBE_LOG_FILE"
: > "$LOG_FILE"

ensure_destination_ready
ensure_work_space_available
wait_for_media

LABEL="$(blkid -o value -s LABEL "$DEV" 2>/dev/null || true)"
LABEL="${LABEL:-DVD}"
SAFE_LABEL="$(printf '%s' "$LABEL" | safe_name)"
SAFE_LABEL="${SAFE_LABEL:-DVD}"

SIZE="$(blockdev --getsize64 "$DEV" 2>/dev/null || echo unknown)"
UUID="$(blkid -o value -s UUID "$DEV" 2>/dev/null || true)"
TYPE="$(blkid -o value -s TYPE "$DEV" 2>/dev/null || true)"
if [ -n "$UUID" ]; then
  append_log "disk identity collected: label=$LABEL uuid=$UUID type=${TYPE:-unknown} size=$SIZE"
else
  append_log "disk UUID unavailable; using label/type/size identity"
fi
FP="$(printf '%s|%s|%s|%s\n' "$LABEL" "$UUID" "$TYPE" "$SIZE" | sha256sum | awk '{print $1}' | cut -c1-20)"

RUN_DIR="$WORK_DIR/$FP"
LOG_FILE="$LOG_DIR/$FP.log"
mv "$PROBE_LOG_FILE" "$LOG_FILE"

if grep -q "\"fingerprint\":\"$FP\"" "$RIPPED_DB" 2>/dev/null; then
  log "Already ripped: $LABEL $FP"
  exit 0
fi

record_success() {
  if grep -q "\"fingerprint\":\"$FP\"" "$RIPPED_DB" 2>/dev/null; then
    return 0
  fi

  jq -cn \
    --arg fingerprint "$FP" \
    --arg disc_label "$LABEL" \
    --arg mode "$RIP_MODE" \
    --arg file "$FINAL" \
    --arg completed_at "$(date -Is)" \
    '{"fingerprint":$fingerprint,"label":$disc_label,"mode":$mode,"file":$file,"completed_at":$completed_at}' \
    >> "$RIPPED_DB"
}

rm -rf "$RUN_DIR"
mkdir -p "$RUN_DIR"
touch "$RUN_DIR/.rip-in-progress"

log "Ripping $LABEL fingerprint=$FP mode=$RIP_MODE from $DEV"

case "$RIP_MODE" in
  movie)
    FINAL="$DEST_DIR/${SAFE_LABEL}_${FP}.mkv"
    PART="$DEST_DIR/.${SAFE_LABEL}_${FP}.mkv.part"
    if [ -f "$FINAL" ]; then
      log "Final file already exists: $FINAL"
      record_success
      rm -rf "$RUN_DIR"
      exit 0
    fi

    write_metadata
    if [ "$PUBLISH_DURING_RIP" = "1" ]; then
      start_publish_async || true
    fi

    run_logged HandBrakeCLI \
      --input "$DEV" \
      --main-feature \
      --preset "$HANDBRAKE_PRESET" \
      --markers \
      --format av_mkv \
      --output "$RUN_DIR/output.mkv"

    ;;
  archive)
    FINAL="$DEST_DIR/${SAFE_LABEL}_${FP}"
    PART="$DEST_DIR/.${SAFE_LABEL}_${FP}.part"
    if [ -e "$FINAL" ]; then
      log "Final archive already exists: $FINAL"
      record_success
      rm -rf "$RUN_DIR"
      exit 0
    fi

    write_metadata
    if [ "$PUBLISH_DURING_RIP" = "1" ]; then
      start_publish_async || true
    fi

    run_logged dvdbackup -M -i "$DEV" -o "$RUN_DIR"
    ;;
  tv)
    echo "RIP_MODE=tv requires a library-specific title-selection policy. MIN_TV_TITLE_SECONDS=$MIN_TV_TITLE_SECONDS" >&2
    exit 2
    ;;
  *)
    echo "Unsupported RIP_MODE=$RIP_MODE" >&2
    exit 2
    ;;
esac

rm -f "$RUN_DIR/.rip-in-progress"
touch "$RUN_DIR/.rip-complete"
append_log "local rip complete; ejecting before final NAS publish"
eject_disc

if [ "$PUBLISH_STARTED" = "0" ]; then
  start_publish
fi
