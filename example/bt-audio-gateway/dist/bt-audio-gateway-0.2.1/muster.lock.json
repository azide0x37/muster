      {
        "id": "implementation:bt-audio-gateway",
        "kind": "implementation",
        "health": {
          "status": "unknown"
        },
        "summary": "Keeps a Snapcast audio path attached to a specific Bluetooth speaker.",
        "children": [
          "component:bt-audio-gateway:services",
          "component:bt-audio-gateway:doctor",
          "component:bt-audio-gateway:configuration",
          "component:bt-audio-gateway:release",
          "component:bt-audio-gateway:patterns"
        ],
        "what": "A small Linux audio appliance whose lifecycle and recovery are owned by systemd.",
        "why": "Bluetooth is an unreliable last hop; the gateway makes that unreliability bounded and inspectable.",
        "responsibilities": [
          "reconnect the configured Bluetooth speaker",
          "route the local audio graph to the selected sink",
          "keep snapclient and scheduled health checks under systemd"
        ],
        "failure_modes": [
          {
            "id": "failure-1",
            "summary": "the configured Bluetooth device is absent or no longer trusted"
          },
          {
            "id": "failure-2",
            "summary": "the PipeWire or Pulse socket is unavailable for the audio user"
          },
          {
            "id": "failure-3",
            "summary": "the Snapserver cannot be reached"
          }
        ]
      },
