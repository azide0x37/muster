#!/usr/bin/env bash
set -euo pipefail

source /etc/bt-audio-gateway/bt-audio-gateway.env

log() {
  echo "$*" | systemd-cat -t bt-audio-watch
}

btctl() {
  timeout --signal=TERM 5 bluetoothctl "$@"
}

initialized=0
while true; do
  if ! systemctl is-active --quiet bluetooth.service; then
    initialized=0
    log "bluetooth.service is not active; waiting before retry"
    sleep "${SLEEP_SECONDS:-8}"
    continue
  fi

  if [ "$initialized" -eq 0 ]; then
    btctl power on >/dev/null 2>&1 || true
    btctl agent on >/dev/null 2>&1 || true
    btctl default-agent >/dev/null 2>&1 || true
    btctl trust "$BT_MAC" >/dev/null 2>&1 || true
    initialized=1
  fi

  INFO="$(btctl info "$BT_MAC" 2>/dev/null || true)"

  if grep -q "Connected: yes" <<< "$INFO"; then
    /opt/bt-audio-gateway/current/bin/bt-audio-route >/dev/null 2>&1 || true
    sleep "${SLEEP_SECONDS:-8}"
    continue
  fi

  log "Bluetooth device not connected. Scanning for $BT_MAC"
  scan_seconds="${SCAN_SECONDS:-12}"
  case "$scan_seconds" in ''|*[!0-9]*) scan_seconds=12 ;; esac
  timeout --signal=TERM "$((scan_seconds + 5))" \
    bluetoothctl --timeout "$scan_seconds" scan on >/dev/null 2>&1 || true

  if btctl devices | grep -qi "$BT_MAC"; then
    log "Device discovered. Connecting to $BT_MAC"
    btctl connect "$BT_MAC" >/dev/null 2>&1 || true
    sleep 3
    /opt/bt-audio-gateway/current/bin/bt-audio-route >/dev/null 2>&1 || true
  fi

  sleep "${SLEEP_SECONDS:-8}"
done
